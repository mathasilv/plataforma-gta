# Copie para .env.local (desenvolvimento) e configure as variáveis abaixo.
# Em PRODUÇÃO (Vercel), defina-as em Settings > Environment Variables.

# Segredo para assinar o cookie de sessão. Gere um valor aleatório longo, ex.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# OBRIGATÓRIO em produção (a aplicação recusa iniciar sem ele).
AUTH_SECRET=

# Usuários autorizados a acessar a plataforma, em JSON.
# Ex.: [{"email":"tito@gta.com","password":"senhaForte","name":"Tito"}]
# OBRIGATÓRIO em produção (sem isto, ninguém consegue entrar).
APP_USERS=

# POSTGRES_URL — NÃO defina manualmente. É criada automaticamente pela Vercel
# ao vincular um banco Vercel Postgres ao projeto. Sem ela, o app usa um
# arquivo local (data/tasks.json) apenas para desenvolvimento.

# --- Anexos dos orçamentos (Vercel Blob) — OPCIONAL em dev ------------------
# Armazena os PDFs/planilhas anexados na aprovação de orçamentos.
# BLOB_READ_WRITE_TOKEN é criada automaticamente pela Vercel ao criar um
# Blob store (Storage > Create > Blob, acesso PÚBLICO). Sem ela, o app grava
# os anexos em data/uploads/ apenas para desenvolvimento local.
BLOB_READ_WRITE_TOKEN=

# Segredo do cron de limpeza de anexos vencidos (retenção 7d/3d). Gere um valor
# aleatório e defina o MESMO na Vercel; o Vercel Cron envia
# "Authorization: Bearer <CRON_SECRET>" para /api/cron/limpar-anexos.
CRON_SECRET=

# --- Notificação por e-mail (OPCIONAL) --------------------------------------
# Envia um e-mail ao responsável quando uma tarefa é criada para ele.
# Fica DESLIGADO enquanto RESEND_API_KEY não for definido (nada é enviado).
# 1) Crie uma conta grátis no Resend (resend.com) e gere uma API key.
# 2) Verifique o domínio gtaenergia.com no Resend (registros DNS) para enviar
#    de um endereço próprio e definir EMAIL_FROM. Sem domínio verificado, o
#    Resend só entrega e-mails de teste para o dono da conta.
RESEND_API_KEY=
# Remetente exibido no e-mail (após verificar o domínio no Resend):
EMAIL_FROM="GTA Energia <tarefas@gtaenergia.com>"
# URL pública da plataforma, usada no botão "Abrir no painel" do e-mail:
APP_URL=
