# Copie para .env.local (desenvolvimento) e configure as variáveis abaixo.
# Em PRODUÇÃO (Vercel), defina-as em Settings > Environment Variables.

# Segredo para assinar o cookie de sessão. Gere um valor aleatório longo, ex.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# OBRIGATÓRIO em produção (a aplicação recusa iniciar sem ele).
AUTH_SECRET=

# Usuários autorizados a acessar a plataforma, em JSON.
# Ex.: [{"email":"tito@gta.com","password":"senhaForte","name":"Tito"}]
# OBRIGATÓRIO em produção (sem isto, ninguém consegue entrar).
APP_USERS=

# POSTGRES_URL — NÃO defina manualmente. É criada automaticamente pela Vercel
# ao vincular um banco Vercel Postgres ao projeto. Sem ela, o app usa um
# arquivo local (data/tasks.json) apenas para desenvolvimento.
